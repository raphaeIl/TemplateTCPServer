<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <!-- Runtime support for the protoc-generated message types in Generated/. -->
    <PackageReference Include="Google.Protobuf" Version="3.28.3" />
    <!-- Stock gRPC codegen: build-time protoc + grpc_csharp_plugin (the normal MS-docs way). -->
    <PackageReference Include="Grpc.Tools" Version="2.66.0" PrivateAssets="All" />
    <PackageReference Include="Grpc.Core.Api" Version="2.66.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Operators drop .proto files into protos/ (git-ignored, updated out-of-band).
         Everything present at build time is compiled to C# automatically. -->
    <Protobuf Include="protos\**\*.proto" GrpcServices="Server" />
  </ItemGroup>

</Project>
